# ============================================================
# POLYMARKET BOT — ENVIRONMENT VARIABLES
# ============================================================
# SICHERHEIT: Diese Datei NIEMALS in Git committen!
# .env ist in .gitignore — .env.example ist das Template.
# ============================================================

# --- WALLET ---
# Dein MetaMask Private Key (64 hex chars, mit oder ohne 0x)
PRIVATE_KEY=0xDEIN_PRIVATE_KEY_HIER

# Deine Polymarket Proxy-Adresse (aus Polymarket UI)
POLYMARKET_ADDRESS=0xDEINE_POLYMARKET_ADRESSE

# --- COPY TRADING TARGETS ---
# Kommagetrennte Wallet-Adressen die kopiert werden sollen
TARGET_WALLETS=0xWALLET_1,0xWALLET_2

# --- RISIKO MANAGEMENT ---
# Maximaler Verlust pro Tag in USD bevor Bot stoppt
MAX_DAILY_LOSS_USD=50

# Maximaler Einsatz pro einzelnem Trade in USD
MAX_TRADE_SIZE_USD=25

# Minimaler Einsatz pro Trade (kleinere Trades ignorieren)
MIN_TRADE_SIZE_USD=2

# Proportionaler Multiplikator (0.1 = 10% der Whale-Position)
COPY_SIZE_MULTIPLIER=0.05

# --- BOT EINSTELLUNGEN ---
# Polling-Intervall in Sekunden (Fallback wenn WebSocket ausfällt)
POLL_INTERVAL_SECONDS=10

# Dry-Run: true = Bot loggt alles aber kauft nichts
DRY_RUN=true

# Log Level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- POLYMARKET API ---
# Standard Werte — nur ändern wenn Polymarket API-Adresse sich ändert
CLOB_HOST=https://clob.polymarket.com
GAMMA_HOST=https://gamma-api.polymarket.com
CHAIN_ID=137

# --- EXIT-MANAGER ---
# WICHTIG: EXIT_DRY_RUN=true für die ersten 24h (nur loggen, nicht verkaufen!)
# Nach Observation auf false setzen um Live-Exits zu aktivieren.
EXIT_ENABLED=true
EXIT_DRY_RUN=true
EXIT_LOOP_INTERVAL=60

# TP-Staffel (Normal): 30% → sell 40% | 60% → sell 40% | 100% → sell 15% | 5% runner
EXIT_TP1_THRESHOLD=0.30
EXIT_TP1_SELL_RATIO=0.40
EXIT_TP2_THRESHOLD=0.60
EXIT_TP2_SELL_RATIO=0.40
EXIT_TP3_THRESHOLD=1.00
EXIT_TP3_SELL_RATIO=0.15

# Boost-Staffel bei >= 3 Wallets gleichzeitig: höhere Schwellen
EXIT_MULTI_SIGNAL_BOOST_MIN=3
EXIT_TP1_THRESHOLD_BOOST=0.50
EXIT_TP2_THRESHOLD_BOOST=0.90
EXIT_TP3_THRESHOLD_BOOST=1.50

# Trailing-Stop: Aktivierung bei 12¢ Gewinn, Trail-Abstand je nach Liquidität
EXIT_TRAIL_ACTIVATION=0.12
EXIT_TRAIL_DISTANCE_LIQUID=0.07
EXIT_TRAIL_DISTANCE_THIN=0.10
EXIT_TRAIL_LIQUIDITY_THRESHOLD=50000

# No-Exit-Filter: Positionen unter $3 oder <24h bis Close werden nicht angerührt
EXIT_MIN_POSITION_USDC=3.0
EXIT_MIN_HOURS_TO_CLOSE=24

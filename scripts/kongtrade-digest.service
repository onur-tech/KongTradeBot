[Unit]
Description=KongTrade Daily Digest (22:00 Berlin)
After=network.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/home/claudeuser/KongTradeBot
ExecStart=/usr/bin/python3 /home/claudeuser/KongTradeBot/scripts/daily_digest.py
Environment=HOME=/root
StandardOutput=journal
StandardError=journal

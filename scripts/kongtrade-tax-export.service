[Unit]
Description=KongTradeBot Weekly Tax Export
After=network.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/root/KongTradeBot
ExecStart=/usr/bin/python3 /root/KongTradeBot/scripts/weekly_tax_export.py
EnvironmentFile=/root/KongTradeBot/.env
StandardOutput=journal
StandardError=journal
